{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "types": ["node"],
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "alwaysStrict": true,
    "skipLibCheck": true,
    "outDir": "./dist/server",
    "types": [
      "vitest/globals"
    ]
  },
  "include": [
    "config/**/*",
    "node_modules/vite/client.d.ts",
    "src/server/**/*"
  ]
}
