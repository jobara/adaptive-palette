{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "types": ["node", "vitest/globals"],
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "alwaysStrict": true,
    "skipLibCheck": true,
    "outDir": "./dist/server"
  },
  "include": [
    "config/**/*",
    "src/server/**/*"
  ]
}
