{
  "name": "adaptive-palette",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "run-s build:* start:server",
    "build:client": "vite build",
    "build:server": "tsc --project tsconfig.node.json",
    "start:server": "node dist/server/src/server/server.js",
    "dev": "run-p dev:* start:devServer",
    "dev:watchClient": "vite build --watch",
    "dev:watchServer": "tsc --project tsconfig.node.json --watch",
    "start:devServer": "wait-on dist/server/src/server/server.js && nodemon dist/server/src/server/server.js",
    "serveAppsDemos": "vite --port 5173",
    "lint": "run-p lint:*",
    "lint:js": "eslint .",
    "lint:markdown": "markdownlint-cli2 \"./**/*.md\" \"#node_modules\" \"#dist\"",
    "test": "run-s test:*",
    "test:server": "vitest server",
    "test:browser": "vitest client --config=vitest.browser.config.ts --browser.headless"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@langchain/community": "^1.1.27",
    "@langchain/core": "^1.1.42",
    "@preact/signals": "^2.9.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/serve-static": "^2.2.0",
    "@xenova/transformers": "^2.13.0",
    "bliss-svg-builder": "^1.0.0-rc.2",
    "express": "^5.2.1",
    "faiss-node": "^0.5.1",
    "htm": "^3.1.1",
    "ollama": "^0.6.3",
    "preact": "^10.23.2",
    "sass": "^1.77.8 ",
    "serve-static": "^2.2.1"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.25.4",
    "@eslint/eslintrc": "^3.1.0",
    "@eslint/js": "^10.0.1",
    "@preact/preset-vite": "^2.9.0",
    "@testing-library/preact": "^3.2.3",
    "@testing-library/user-event": "^14.6.1",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitest/browser-playwright": "^4.1.5",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "markdownlint-cli2": "^0.22.1",
    "nodemon": "^3.1.4",
    "npm-run-all2": "^8.0.4",
    "typescript": "^6.0.3",
    "uuid": "^14.0.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "vitest-browser-preact": "^1.0.0",
    "wait-on": "^9.0.5"
  }
}
